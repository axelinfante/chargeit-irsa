# Firebase / Firestore — copiar a .env y rellenar con tu Service Account.
# No subir .env al repositorio.
#
# Colecciones usadas:
#   - config: documentos espiral1, espiral2, espiral3, espiral4 (campo "stock").
#   - history: documentos con tipo, codigo, cantidad, fecha (ej. eventos de retiro).

# Código secreto para entrar al menú de administración.
CODIGO_ADMIN=admin1234

# API de validación y redención de códigos
url_api=https://apis-uat.getappa.com.ar/v3
storeId=store-123
x-api-key=tu-api-key-aqui
# Código de la máquina para POST redemptions (trazabilidad)
vendingCode=VM-12345

FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# SMTP — notificaciones por correo (stock espirales)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM=tu-correo@gmail.com
# Destinatarios de alertas (separados por comas)
NOTIFICATION_EMAILS=alerta1@ejemplo.com,alerta2@ejemplo.com


