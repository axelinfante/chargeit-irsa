# Firebase / Firestore — copiar a .env y rellenar con tu Service Account.
# No subir .env al repositorio.
#
# Colecciones usadas:
#   - config: documentos espiral1, espiral2, espiral3, espiral4 (campo "stock").
#   - history: documentos con tipo, codigo, cantidad, fecha (ej. eventos de retiro).

# Código secreto para entrar al menú de administración.
CODIGO_ADMIN=admin1234

FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
